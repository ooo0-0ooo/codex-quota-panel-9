{
  "name": "codex-quota-panel-9",
  "version": "1.5.0",
  "description": "A Windows Codex quota panel synchronized through the official Codex app-server.",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "ooo0-0ooo",
  "license": "MIT",
  "private": false,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test",
    "capture": "electron tests/capture.cjs",
    "generate:icon": "electron scripts/generate-icon.cjs",
    "build": "electron-builder --win nsis portable --publish never",
    "build:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.ooo0-0ooo.codex-quota-panel-9",
    "productName": "Codex Quota Panel",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "src/assets/logo.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
